# Copy to .env.local for local development.

# Runtime model selection
PERSONAL_AGENT_PROVIDER=openai
PERSONAL_AGENT_MODEL=gpt-5.4-mini

# Optional ports for local demos
PERSONAL_AGENT_STATIC_PORT=4174
PERSONAL_AGENT_SIDECAR_PORT=8787

# Optional overrides for local host binaries
# PERSONAL_AGENT_HOST_BIN=/absolute/path/to/personal-agent-host
# PERSONAL_AGENT_FILECHANNEL_SMOKE_BIN=/absolute/path/to/personal-agent-filechannel-smoke
# PERSONAL_AGENT_SYSTEMCHANNEL_SMOKE_BIN=/absolute/path/to/personal-agent-systemchannel-smoke
# PERSONAL_AGENT_HOST_BUILD_DIR=/absolute/path/to/build-dir

# Provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
